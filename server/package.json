{
  "name": "server",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "build": "node scripts/build.js",
    "prisma:generate": "npx prisma@6.3.0 generate",

    "clean": "shx rm -rf dist",
    "compile": "npx tsc",
    "start": "node dist/src/index.js",
    "dev": "node scripts/build.js; concurrently \"npx tsc -w\" \"nodemon --exec ts-node src/index.ts\"",


    "seed": "ts-node prisma/seed.ts",
    "postprisma:generate": "shx cp -r node_modules/.prisma/client/index.d.ts ../client/src/types/prismaTypes.d.ts"

  },
